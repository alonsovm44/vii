# Test for put append mode
path = "temp_log.txt"

path put "Line 1\n" # think of it saying 'in path put "line 1\n" i am just too lazy to ad in keyword
path put "Line 2\n" append # if we didn't use append, it would overwrite the file with just line 2
path put "Line 3\n" append

content = path ask
content          # Should show all three lines