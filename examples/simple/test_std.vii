# Test lib/std.vii
paste "lib/std.vii"

"--- std ---"
x = -5
v = abs x
"abs(-5): " + tostr v
v = abs 3
"abs(3): " + tostr v
v = min 3 7
"min(3,7): " + tostr v
v = max 3 7
"max(3,7): " + tostr v
v = clamp 15 0 10
"clamp(15,0,10): " + tostr v
y = - 3
v = clamp y 0 10
"clamp(-3,0,10): " + tostr v
z = - 7
v = sign z
"sign(-7): " + tostr v
v = sign 0
"sign(0): " + tostr v
v = sign 5
"sign(5): " + tostr v
