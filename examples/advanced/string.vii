# C like strings

string_ptr ptr str = heap_alloc(6) # allocate 6 bytes for the string "Hello" and a null terminator

string_ptr at 0 = 'H'
string_ptr at 1 = 'e'
string_ptr at 2 = 'l'
string_ptr at 3 = 'l'
string_ptr at 4 = 'o'
string_ptr at 5 = 0

# although you could just use 

string str = "hello" # this will create a string literal 
