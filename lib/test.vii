# Vii Standard Library — Testing Framework

do assert condition msg
  # Fails process if condition is 0
  if condition == 0
    "Assertion failed: " + msg
    exit 1

do run_test name result->bit
  if result == 1
    "PASS: " + name
  else
    "FAIL: " + name

do run_tests
  "Running Vii Test Suite..."
  # Integration point for library tests
  1
  0