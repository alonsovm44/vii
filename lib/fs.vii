# Vii Standard Library — File System Utilities (via sys)

do ls path
  # Returns list of files in directory
  sys "ls " + path

do mkdir path
  # Creates directory
  sys "mkdir " + path

do rm path
  # Removes file or directory
  sys "rm -rf " + path

do cp src dst
  # Copies file
  sys "cp " + src + " " + dst

do mv src dst
  # Moves/Renames file
  sys "mv " + src + " " + dst