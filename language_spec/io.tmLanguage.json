{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "IO",
    "scopeName": "source.io",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#function-definitions" },
        { "include": "#keywords" },
        { "include": "#numbers" },
        { "include": "#operators" },
        { "include": "#identifiers" }
    ],
    "repository": {
        "comments": {
            "match": "#.*$",
            "name": "comment.line.number-sign.io"
        },
        "strings": {
            "name": "string.quoted.double.io",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape.io",
                    "match": "\\\\."
                }
            ]
        },
        "function-definitions": {
            "match": "\\b(do)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
            "captures": {
                "1": { "name": "keyword.control.io" },
                "2": { "name": "entity.name.function.io" }
            }
        },
        "keywords": {
            "patterns": [
                {
                    "match": "\\b(if|else|while)\\b",
                    "name": "keyword.control.io"
                },
                {
                    "match": "\\b(ask|put|paste|list|at|set|len|ord|chr|tonum|tostr)\\b",
                    "name": "support.function.io"
                },
                {
                    "match": "\\b(arg)\\b",
                    "name": "variable.language.io"
                },
                {
                    "match": "\\b(num|str)\\b",
                    "name": "storage.type.io"
                }
            ]
        },
        "numbers": {
            "match": "\\b([0-9]+(\\.[0-9]+)?)\\b",
            "name": "constant.numeric.io"
        },
        "operators": {
            "patterns": [
                {
                    "match": "==",
                    "name": "keyword.operator.comparison.io"
                },
                {
                    "match": "->",
                    "name": "keyword.operator.type.io"
                },
                {
                    "match": "=",
                    "name": "keyword.operator.assignment.io"
                },
                {
                    "match": "\\+|-|\\*|/|%",
                    "name": "keyword.operator.arithmetic.io"
                },
                {
                    "match": "<|>",
                    "name": "keyword.operator.comparison.io"
                }
            ]
        },
        "identifiers": {
            "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b",
            "name": "variable.other.io"
        }
    }
}