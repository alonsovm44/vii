{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Vii",
    "scopeName": "source.vii",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#function-definitions" },
        { "include": "#constants" },
        { "include": "#keywords" },
        { "include": "#numbers" },
        { "include": "#operators" },
        { "include": "#identifiers" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.block.vii",
                    "begin": "#\\{",
                    "end": "\\}#"
                },
                {
                    "name": "comment.line.number-sign.vii",
                    "match": "#.*$"
                }
            ]
        },
        "strings": {
            "name": "string.quoted.double.vii",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape.vii",
                    "match": "\\\\."
                }
            ]
        },
        "function-definitions": {
            "match": "\\b(do)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
            "captures": {
                "1": { "name": "keyword.control.vii" },
                "2": { "name": "entity.name.function.vii" }
            }
        },
        "keywords": {
            "patterns": [
                {
                "match": "\\b(if|else|while|do|break|IF|ELSE)\\b",
                    "name": "keyword.control.vii"
                },
                {
                "match": "\\b(ask|put|paste|list|at|set|len|ord|chr|tonum|tostr|sys|env|exit|dict|key|slice|type|time|append|ref)\\b",
                    "name": "support.function.vii"
                },
                {
                    "match": "\\b(arg)\\b",
                    "name": "variable.language.vii"
            },
            {
                "match": "\\b(and|or)\\b",
                "name": "keyword.operator.logical.vii"
                },
                {
                    "match": "\\b(num|str|ref|ptr)\\b",
                    "name": "storage.type.vii"
                }
            ]
        },
    "constants": {
        "match": "\\b[A-Z_][A-Z0-9_]*\\b",
        "name": "variable.other.constant.vii"
    },
        "numbers": {
            "match": "\\b([0-9]+(\\.[0-9]+)?)\\b",
            "name": "constant.numeric.vii"
        },
        "operators": {
            "patterns": [
                {
                "match": "==|!=|<=|>=|<|>",
                    "name": "keyword.operator.comparison.vii"
                },
                {
                    "match": "->",
                    "name": "keyword.operator.type.vii"
                },
                {
                    "match": "=",
                    "name": "keyword.operator.assignment.vii"
                },
                {
                    "match": "\\+|-|\\*|/|%",
                    "name": "keyword.operator.arithmetic.vii"
                }
            ]
        },
        "identifiers": {
            "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b",
            "name": "variable.other.vii"
        }
    }
}